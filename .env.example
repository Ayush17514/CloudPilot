# CloudPilot AI — Environment Configuration
# ============================================

# GEMINI_API_KEY: Required for Gemini AI-powered analysis.
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="http://localhost:3000"

# PHOENIX_ENABLED: Set to "true" to enable Arize Phoenix OTel tracing.
# Requires a running Phoenix collector (default: http://localhost:6006).
# Set to "false" to disable tracing entirely.
PHOENIX_ENABLED="true"

# PHOENIX_COLLECTOR_ENDPOINT: Override the default Phoenix collector URL.
# Only needed if running a remote Phoenix instance.
# PHOENIX_COLLECTOR_ENDPOINT="http://localhost:6006"

# NODE_ENV: Set by platform automatically in production.
# NODE_ENV="development"
